# GrowRight Environment Configuration
# Author: Sourojit D <soft.jd4u@gmail.com>
# See QUICKSTART.md for setup instructions

# ─── Application ─────────────────────────────────────
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
API_VERSION=v1

# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql://growright:growright_secret@localhost:5432/growright?schema=public

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Authentication ──────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Email (future) ─────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@growright.app

# ─── AI / LLM Abstraction (future) ──────────────────
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=

# ─── Observability ───────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ─── Feature Flags ───────────────────────────────────
ENABLE_AI_ROADMAP=false
ENABLE_SUBSCRIPTION_BILLING=false
